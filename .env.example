# ============================================================
# UMUKINO — Environment Variables
# Copy this file to .env and fill in values
# ============================================================

# --- App ---
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:3003

# --- Database ---
POSTGRES_USER=umukino
POSTGRES_PASSWORD=umukino_dev_pw
POSTGRES_DB=umukino

# --- MongoDB ---
MONGO_USER=umukino
MONGO_PASSWORD=umukino_dev_pw

# --- Redis ---
# No password in dev; add requirepass in prod

# --- JWT (generate strong random secrets for production!) ---
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_256bit_minimum_please_change
JWT_REFRESH_SECRET=change_me_refresh_secret_256bit_minimum_please_change

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# --- MTN MoMo (set MOCK=false + fill credentials for live) ---
MTN_MOMO_MOCK=true
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_COLLECTION_USER_ID=
MTN_MOMO_COLLECTION_KEY=
MTN_MOMO_DISBURSEMENT_USER_ID=
MTN_MOMO_DISBURSEMENT_KEY=

# --- Airtel Money (set MOCK=false + fill credentials for live) ---
AIRTEL_MOCK=true
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_PIN=

# --- USDT (set MOCK=false + fill for live) ---
USDT_MOCK=true
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# --- Email (for notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@umukino.rw

# --- Platform ---
PLATFORM_CUT_PERCENT=10
